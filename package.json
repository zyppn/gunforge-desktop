{
  "name": "gunforge",
  "productName": "GUNFORGE",
  "version": "1.0.0",
  "description": "Arena shooter with persistent loot, part sets and a live auction house",
  "main": "main.js",
  "author": "Jacob Phillips",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux"
  },
  "devDependencies": {
    "electron": "^31.3.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.zyppn.gunforge",
    "productName": "GUNFORGE",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": false
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.games"
    },
    "linux": {
      "target": "AppImage",
      "category": "Game"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "zyppn",
        "repo": "gunforge-desktop"
      }
    ]
  },
  "dependencies": {
    "electron-updater": "^6.3.4"
  }
}